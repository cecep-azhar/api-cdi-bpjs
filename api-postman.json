{
    "info": {
        "_postman_id": "c7a8b9d0-1e2f-4a3b-8c9d-0e1f2a3b4c5d",
        "name": "CDI BPJS - Medical Master Data API",
        "description": "API collection untuk Sinkronisasi Master Data Tindakan (Procedures), Diagnosa (Diagnoses), dan BPJS Mappings. Author: Cecep Saeful Azhar Hidayat, ST",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "🔄 Sync",
            "item": [
                {
                    "name": "GET Sync Delta (Pull dari Cloud)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/sync/get?last_sync=0&type=procedures,diagnoses,bpjs",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "sync", "get"],
                            "query": [
                                {
                                    "key": "last_sync",
                                    "value": "0",
                                    "description": "Unix timestamp (ms). Gunakan 0 untuk ambil semua data."
                                },
                                {
                                    "key": "type",
                                    "value": "procedures,diagnoses,bpjs",
                                    "description": "Filter data: procedures, diagnoses, bpjs, icd10, icd9, tariffs. Pisahkan dengan koma."
                                }
                            ]
                        },
                        "description": "Ambil data master yang berubah sejak `last_sync`. Gunakan parameter `type` untuk memfilter entitas tertentu (misal: procedures, diagnoses, bpjsMappings)."
                    },
                    "response": []
                },
                {
                    "name": "POST Sync (Push ke Cloud)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"procedures\": [\n    {\n      \"cdiCode\": \"P001\",\n      \"name\": \"Konsultasi Dokter Umum\",\n      \"description\": \"Layanan konsultasi dasar\",\n      \"isActive\": true\n    }\n  ],\n  \"diagnoses\": [\n    {\n      \"cdiCode\": \"D001\",\n      \"name\": \"Influenza\",\n      \"description\": \"Flu biasa\",\n      \"isActive\": true\n    }\n  ],\n  \"bpjsMappings\": [\n    {\n      \"bpjsCode\": \"B001\",\n      \"baseTariff\": 50000,\n      \"isActive\": true\n    }\n  ],\n  \"icd10\": [],\n  \"icd9\": [],\n  \"tariffs\": []\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/sync/post",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "sync", "post"]
                        },
                        "description": "Push data dari desktop ke cloud. Field: procedures, diagnoses, bpjsMappings, icd10, icd9, tariffs."
                    },
                    "response": []
                }
            ]
        },
