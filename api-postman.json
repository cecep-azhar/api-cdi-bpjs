{
    "info": {
        "_postman_id": "c7a8b9d0-1e2f-4a3b-8c9d-0e1f2a3b4c5d",
        "name": "Medical Master Data API",
        "description": "API collection for testing Tindakan, Diagnosa, and BPJS master data synchronization.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Master Data",
            "item": [
                {
                    "name": "Get Procedures",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/procedures",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "procedures"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Diagnoses",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/diagnoses",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "diagnoses"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get BPJS",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/bpjs",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "bpjs"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Sync",
            "item": [
                {
                    "name": "Post Sync Data",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{apiKey}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"procedures\": [\n    {\n      \"cdiCode\": \"T001\",\n      \"name\": \"Konsultasi Dokter Umum\",\n      \"description\": \"Layanan konsultasi dasar\",\n      \"isActive\": true\n    }\n  ],\n  \"diagnoses\": [\n    {\n      \"cdiCode\": \"D001\",\n      \"name\": \"Influenza\",\n      \"description\": \"Flu biasa\",\n      \"isActive\": true\n    }\n  ],\n  \"bpjsMappings\": [\n    {\n      \"bpjsCode\": \"B001\",\n      \"baseTariff\": 50000,\n      \"isActive\": true\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/sync/post",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "sync",
                                "post"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "apiKey",
            "value": "YOUR_API_KEY_HERE",
            "type": "string"
        }
    ]
}